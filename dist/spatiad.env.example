# Spatiad Configuration
# Copy this to /etc/spatiad/spatiad.env and customize for your environment

# Logging level: trace, debug, info, warn, error
SPATIAD_LOG_LEVEL=info

# Bind address for HTTP and WebSocket
SPATIAD_BIND_ADDR=0.0.0.0:3000

# H3 spatial index resolution (0-15, lower = broader cells)
# Lower = faster candidate lookup but less precise
# Higher = more precise but slower and uses more memory
SPATIAD_H3_RESOLUTION=8

# Dispatch API rate limit (requests per minute)
# Default: 240 (4 requests per second)
SPATIAD_DISPATCH_RATE_LIMIT_PER_MIN=240

# WebSocket reconnect rate limit (reconnects per minute)
# Prevents driver reconnect storms
SPATIAD_WS_RECONNECT_MAX_PER_MIN=30

# Webhook configuration (optional)
# URL where matched job notifications will be sent
# SPATIAD_WEBHOOK_URL=http://webhook-receiver:4000/webhooks/spatiad

# Webhook signature secret (required if SPATIAD_WEBHOOK_URL is set)
# Used to sign webhook payloads with HMAC-SHA256
# SPATIAD_WEBHOOK_SECRET=your-secret-key

# Dispatcher API authentication (optional)
# If set, all dispatcher endpoints require Authorization header
# SPATIAD_DISPATCHER_TOKEN=dispatcher-token

# Driver WebSocket authentication (optional)
# If set, driver WebSocket upgrade requires x-spatiad-driver-token header
# SPATIAD_DRIVER_TOKEN=driver-token
